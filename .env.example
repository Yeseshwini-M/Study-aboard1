# Environment Variables – Template
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=3000

# Session Secret (use a long random string in production!)
SESSION_SECRET=your_secret_key_here

# Admin Credentials (change immediately after setup!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Database
DB_PATH=./database.sqlite

# ── Email Configuration (Gmail SMTP) ──────────────────────────────────────────
# GMAIL_USER: the Gmail address emails will be sent FROM
# GMAIL_APP_PASSWORD: a Gmail App Password (NOT your normal password)
#   Generate one at: https://myaccount.google.com/apppasswords
#
GMAIL_USER=yourcompany@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Optional: recipient of admin new-submission alerts (defaults to GMAIL_USER)
ADMIN_NOTIFY_EMAIL=
